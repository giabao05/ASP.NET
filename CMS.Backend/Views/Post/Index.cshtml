@model IEnumerable<CMS.Data.Entitis.Post>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Danh sách bài viết";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">📋 DANH SÁCH BÀI VIẾT</h2>
        <a asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <h4>Chưa có bài viết nào</h4>
            <p class="mb-0">Hãy tạo bài viết đầu tiên của bạn!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var post in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 hover-shadow">

                        <!-- Ảnh đại diện -->
                        <div style="height: 220px; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <img src="@post.ImageUrl"
                                     class="card-img-top"
                                     alt="@post.Title"
                                     style="width: 100%; height: 100%; object-fit: cover;">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
                                    <i class="bi bi-image" style="font-size: 3.5rem;"></i>
                                </div>
                            }
                    </div>

                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-primary mb-2" style="width: fit-content;">
                            @post.Category?.Name
                        </span>

                        <h5 class="card-title fw-bold mb-2">@post.Title</h5>

                        <p class="card-text text-muted flex-grow-1">
                            @(post.Content?.Length > 120
                                                    ? post.Content.Substring(0, 120) + "..."
                                                    : post.Content)
                    </p>
                </div>

                        <div class="card-footer bg-white border-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                            @if (post.CreatedDate != null)
                                    {
                                        @post.CreatedDate.ToString("dd/MM/yyyy")
                                    }
                                </small>

                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@post.Id" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@post.Id" method="post"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này?');" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-shadow {
        transition: all 0.3s ease;
    }

        .hover-shadow:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }

    .card-img-top {
        transition: transform 0.4s ease;
    }

    .card:hover .card-img-top {
        transform: scale(1.05);
    }
</style>
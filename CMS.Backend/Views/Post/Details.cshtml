@model CMS.Data.Entitis.Post

@{
    ViewData["Title"] = Model?.Title ?? "Chi tiết bài viết";
}

<div class="container mt-5 mb-5" style="max-width: 800px;">
    <div class="mb-4">
        <a asp-controller="Post" asp-action="Index" asp-route-id="@Model.CategoryId" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách bài viết
        </a>
    </div>

    <article>
        <h1 class="fw-bold text-dark mb-3 display-5">@Model.Title</h1>

        <div class="d-flex align-items-center text-muted mb-4 pb-3 border-bottom">
            <span class="badge bg-primary me-3 px-2 py-1">
                <i class="bi bi-folder"></i> @Model.Category?.Name
            </span>
            <span class="small me-3">
                <i class="bi bi-calendar3"></i> Ngày đăng: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
            </span>
            <span class="small text-secondary">
                Tác giả: Lê Gia Bảo
            </span>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="text-center mb-4">
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Title" style="max-height: 450px; width: 100%; object-fit: cover;">
            </div>
        }

        <div class="content-body text-secondary lh-lg fs-5 text-justify mt-4" style="white-space: pre-line;">
            @Model.Content
        </div>
    </article>

    <div class="mt-5 p-4 bg-light rounded border-start border-primary border-4 shadow-sm">
        <h5 class="fw-bold text-primary">Thông tin bản quyền</h5>
        <p class="mb-0 text-muted small">Bài viết này thuộc bản quyền hệ thống CMS của sinh viên <strong>Lê Gia Bảo (MSSV: 2123110193)</strong>. Vui lòng không sao chép khi chưa có sự đồng ý.</p>
    </div>
</div>
@model CMS.Data.Entitis.Post
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Chỉnh sửa bài viết";
    var categories = ViewBag.CategoryList as List<CMS.Data.Entitis.Category>;
}

<div class="container mt-4" style="max-width: 950px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">✏️ Chỉnh sửa bài viết</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chuyên mục</label>
                            <select asp-for="CategoryId" class="form-select" required>
                                @if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề</label>
                            <input asp-for="Title" class="form-control" required />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <!-- ==================== ẢNH ĐẠI DIỆN ==================== -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Ảnh đại diện</label>

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mb-3">
                                    <p class="text-muted small mb-1">Ảnh hiện tại:</p>
                                    <img src="@Model.ImageUrl" alt="Ảnh hiện tại"
                                         style="max-width: 300px; max-height: 200px; border-radius: 8px; border: 2px solid #ddd;" />
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label">Chọn ảnh mới từ máy tính</label>
                                <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                                <small class="text-muted">jpg, png, gif, webp (tối đa 5MB)</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ImageUrl" class="form-label">Hoặc dán link ảnh trực tiếp</label>
                                <input asp-for="ImageUrl" class="form-control"
                                       placeholder="https://example.com/anh-bai-viet.jpg" />
                                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Nội dung bài viết</label>
                    <textarea asp-for="Content" class="form-control" rows="12" required></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">Hủy</a>
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-save"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
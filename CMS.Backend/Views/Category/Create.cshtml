@model CMS.Data.Entitis.Category

@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="mb-4 text-primary">THÊM DANH MỤC MỚI</h2>

    <form asp-controller="Category" asp-action="Create" method="post" class="p-4 border rounded shadow-sm bg-light">

        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Tên danh mục:</label>
            <input asp-for="Name" class="form-control" placeholder="Nhập tên chuyên mục..." required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold">Mô tả:</label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Lưu vào hệ thống</button>
            <a asp-controller="Category" asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị Hệ Thống CMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: rgba(255,255,255,0.8);
                text-decoration: none;
                padding: 12px 20px;
                display: block;
                transition: all 0.3s;
            }

                .sidebar a:hover, .sidebar a.active {
                    background-color: #0d6efd;
                    color: white;
                    padding-left: 25px;
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2 px-0 sidebar shadow">
                <div class="p-3 bg-dark text-center border-bottom border-secondary">
                    <h5 class="mb-0 fw-bold text-primary text-uppercase">CMS PANEL</h5>
                    <small class="text-muted">Admin: Lê Gia Bảo</small>
                </div>
                <div class="pt-3">
                    <a asp-controller="Category" asp-action="Index"><i class="bi bi-folder-fill me-2"></i> Quản lý danh mục</a>
                    <a asp-controller="Post" asp-action="Create"><i class="bi bi-pencil-square me-2"></i> Đăng bài viết mới</a>
                    <a href="/" target="_blank"><i class="bi bi-globe me-2"></i> Xem trang chủ chính</a>
                </div>
            </div>

            <div class="col-md-9 col-lg-10 px-4 pt-4">
                <header class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom bg-white p-3 rounded shadow-sm">
                    <span class="fs-5 fw-semibold text-secondary">Trang quản trị nội dung</span>
                    <span class="badge bg-primary px-3 py-2">MSSV: 2123110193</span>
                </header>

                <main class="bg-white p-4 rounded shadow-sm" style="min-height: 70vh;">
                    @RenderBody()
                </main>

                <footer class="text-center text-muted py-4 mt-4 border-top">
                    &copy; 2026 - CMS Backend - Sinh viên: <strong>Lê Gia Bảo (CCQ2311F)</strong>
                </footer>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
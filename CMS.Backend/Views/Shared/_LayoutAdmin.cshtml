<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị CMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: rgba(255,255,255,0.8);
                text-decoration: none;
                padding: 12px 20px;
                display: block;
                transition: all 0.3s;
            }

                .sidebar a:hover, .sidebar a.active {
                    background-color: #0d6efd;
                    color: white;
                    padding-left: 25px;
                    font-weight: bold;
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2 px-0 sidebar shadow">
                <div class="p-3 bg-dark text-center border-bottom border-secondary">
                    <h5 class="mb-0 fw-bold text-primary text-uppercase">CMS PANEL</h5>
                    <small class="text-muted">Admin: Lê Gia Bảo</small>
                </div>
                <div class="pt-3">
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Bảng điều khiển</a>

                    <h6 class="text-muted ps-3 mt-3 text-uppercase small fw-bold">Nội dung</h6>
                    <a asp-controller="Category" asp-action="Index"><i class="bi bi-grid me-2"></i> Danh mục bài viết</a>
                    <a asp-controller="Post" asp-action="Index"><i class="bi bi-file-earmark-post me-2"></i> Quản lý Bài viết</a>

                    <h6 class="text-muted ps-3 mt-3 text-uppercase small fw-bold">Sản phẩm & Bán hàng</h6>
                    <a asp-controller="CategoryProducts" asp-action="Index"><i class="bi bi-tags me-2"></i> Danh mục sản phẩm</a>
                    <a asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam me-2"></i> Quản lý Sản phẩm</a>
                    <a asp-controller="Orders" asp-action="Index"><i class="bi bi-cart-check me-2"></i> Quản lý Đơn hàng</a>
                    <a asp-controller="OrderDetails" asp-action="Index"><i class="bi bi-receipt me-2"></i> Chi tiết đơn hàng</a>
                    <a asp-controller="Customers" asp-action="Index"><i class="bi bi-person-badge me-2"></i> Khách hàng</a>

                    <h6 class="text-muted ps-3 mt-3 text-uppercase small fw-bold">Hệ thống</h6>
                    <a asp-controller="User" asp-action="Index"><i class="bi bi-people me-2"></i> Quản lý Thành viên</a>
                </div>
            </div>

            <div class="col-md-9 col-lg-10 px-4 pt-4">
                <header class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom bg-white p-3 rounded shadow-sm">
                    <span class="fs-5 fw-semibold text-secondary">Trang quản trị nội dung</span>

                    <div class="d-flex align-items-center">
                        <span class="badge bg-primary px-3 py-2 fs-6 me-3">MSSV: 2123110193</span>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-dark dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-success" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        }
                    </div>
                </header>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
                }

                <main class="bg-white p-4 rounded shadow-sm" style="min-height: 70vh;">
                    @RenderBody()
                </main>

                <footer class="text-center text-muted py-4 mt-4 border-top">
                    &copy; 2026 - CMS Backend - Sinh viên: <strong>Lê Gia Bảo (CCQ2311F)</strong>
                </footer>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var currentUrl = window.location.pathname.toLowerCase();
            document.querySelectorAll('.sidebar a').forEach(function (link) {
                var href = link.getAttribute('href').toLowerCase();
                if (currentUrl.includes(href.split('/')[1]) && href !== '/') link.classList.add('active');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS Backend</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: rgba(255,255,255,0.8);
                text-decoration: none;
                padding: 12px 20px;
                display: block;
                transition: 0.3s;
            }

                .sidebar a:hover, .sidebar a.active {
                    background-color: #0d6efd;
                    color: white;
                    padding-left: 25px;
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2 px-0 sidebar">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h5 class="text-primary fw-bold">CMS PANEL</h5>
                </div>
                <nav class="pt-3">
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="CategoryProducts" asp-action="Index"><i class="bi bi-tags me-2"></i> Danh mục sản phẩm</a>
                    <a asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam me-2"></i> Quản lý sản phẩm</a>
                    <a asp-controller="Orders" asp-action="Index"><i class="bi bi-cart-check me-2"></i> Đơn hàng</a>
                </nav>
            </div>

            <div class="col-md-9 col-lg-10 p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <div class="bg-white p-4 rounded shadow-sm">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var currentPath = window.location.pathname;
            var navLinks = document.querySelectorAll('.sidebar a');
            navLinks.forEach(function (link) {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });
    </script>
</body>
</html>
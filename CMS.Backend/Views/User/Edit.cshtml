@model CMS.Data.Entitis.User

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập nhật thành viên";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex align-items-center">
            <h5 class="mb-0 text-uppercase fw-bold">
                <i class="bi bi-pencil-square me-2"></i>Cập nhật thông tin thành viên
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập (Username):</label>
                        <input asp-for="Username" class="form-control bg-light" readonly />
                        <small class="text-muted">* Tên đăng nhập cố định, không thể thay đổi.</small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới (Nếu có):</label>
                        <input type="password" name="NewPassword" class="form-control" placeholder="Bỏ trống nếu giữ nguyên mật khẩu cũ" />
                        <small class="text-danger">* Chỉ nhập khi bạn muốn đổi mật khẩu cho thành viên này.</small>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Họ và Tên:</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên mới..." required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Vai trò (Role):</label>
                        <select asp-for="Role" class="form-select" required>
                            <option value="">-- Chọn quyền hạn --</option>
                            <option value="Admin">Quản trị viên (Admin)</option>
                            <option value="Editor">Biên tập viên (Editor)</option>
                        </select>
                    </div>
                </div>

                <div class="mt-3 border-top pt-3 text-end">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-save me-2"></i>Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
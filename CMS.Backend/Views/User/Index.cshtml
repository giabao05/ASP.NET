@model IEnumerable<CMS.Data.Entitis.User>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Thành viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-0 fw-bold text-dark text-uppercase">
            <i class="bi bi-people-fill text-primary me-2"></i>Quản lý Thành viên
        </h3>
        <small class="text-muted">Danh sách tài khoản quản trị hệ thống</small>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle-fill me-2"></i>Thêm thành viên mới
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped align-middle border">
        <thead class="table-dark">
            <tr>
                <th style="width: 8%">Mã số (ID)</th>
                <th>Tên đăng nhập (Username)</th>
                <th>Họ và Tên</th>
                <th style="width: 15%">Vai trò (Role)</th>
                <th style="width: 20%" class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-bold">#@user.Id</td>
                        <td><code class="fs-6">@user.Username</code></td>
                        <td>@user.FullName</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger px-3 py-2">Quản trị viên (Admin)</span>
                            }
                            else
                            {
                                <span class="badge bg-success px-3 py-2">Biên tập viên (Editor)</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil-square me-1"></i>Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên @user.Username không?')">
                                <i class="bi bi-trash3-fill me-1"></i>Xóa
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        Chưa có thành viên nào trong cơ sở dữ liệu. Nhấn "Thêm thành viên mới" để khởi tạo!
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@model IEnumerable<CMS.Data.Entitis.CategoryProduct>

@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý danh mục sản phẩm</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm danh mục</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>Tên danh mục</th>
            <th>Mô tả</th>
            <th style="width: 150px;">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>

                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Bạn chắc chắn muốn xóa danh mục này?')">
                                Xóa
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">Chưa có dữ liệu danh mục nào.</td>
            </tr>
        }
    </tbody>
</table>